# Release bundle runtime
BRIDGE_VERSION=__BRIDGE_VERSION__
HOST_PORT=11958

# Weixin upstream
WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
WEIXIN_BOT_TYPE=3

# Runner
RUNNER_BASE_URL=http://agent-platform-runner:8080
RUNNER_AGENT_KEY=replace-with-runner-agent-key
RUNNER_BEARER_TOKEN=

# Host path for persistent Weixin login/session state.
HOST_STATE_DIR=./runtime/weixin-state

# Runtime
LOG_LEVEL=info
AUTO_START_POLL=true
