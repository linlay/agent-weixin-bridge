BRIDGE_HTTP_ADDR=:11958
WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
WEIXIN_BOT_TYPE=3
# Set to http://127.0.0.1:11949 for local go run, or http://host.docker.internal:11949 for docker compose.
RUNNER_BASE_URL=http://127.0.0.1:11949
RUNNER_AGENT_KEY=demoModeReact
RUNNER_BEARER_TOKEN=
# Local run can keep ./var/state. docker compose mounts HOST_STATE_DIR to /app/var/state and overrides STATE_DIR automatically.
STATE_DIR=./var/state
HOST_STATE_DIR=./runtime/weixin-state
LOG_LEVEL=info
AUTO_START_POLL=true
